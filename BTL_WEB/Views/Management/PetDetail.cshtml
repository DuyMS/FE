@model BTL_WEB.Models.ViewModels.PetDetailViewModel

@{
    ViewData["Title"] = "Chi tiết thú cưng";
    Layout = "~/Views/Shared/_LayoutPetcarehub.cshtml";

    string ResolveImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
        {
            return Url.Content("~/LayoutPetcare/images/gallery-1.jpg");
        }

        imageUrl = imageUrl.Replace("\\", "/");
        if (Uri.IsWellFormedUriString(imageUrl, UriKind.Absolute))
        {
            return imageUrl;
        }

        return imageUrl.StartsWith("/") ? Url.Content($"~{imageUrl}") : Url.Content($"~/{imageUrl}");
    }

    var images = Model.ImageUrls.Count > 0 ? Model.ImageUrls : new List<string> { "~/LayoutPetcare/images/gallery-1.jpg" };
}

<section class="ftco-section bg-light pet-detail-page">
    <div class="container">
        <div class="row mb-3">
            <div class="col-12">
                <a class="btn btn-outline-secondary" asp-action="Pets">&larr; Quay lại Pet Gallery</a>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <div id="petImageCarousel" class="carousel slide shadow-sm" data-ride="carousel">
                    <div class="carousel-inner rounded">
                        @for (var i = 0; i < images.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                                <img src="@ResolveImageUrl(images[i])"
                                     class="d-block w-100"
                                     style="height:430px;object-fit:cover;"
                                     alt="@Model.Name" />
                            </div>
                        }
                    </div>
                    <a class="carousel-control-prev" href="#petImageCarousel" role="button" data-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="sr-only">Previous</span>
                    </a>
                    <a class="carousel-control-next" href="#petImageCarousel" role="button" data-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="sr-only">Next</span>
                    </a>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="mb-3">@Model.Name</h2>
                        <div class="detail-meta">
                            <p><strong>Microchip ID:</strong> @Model.MicrochipId</p>
                            <p><strong>Loài:</strong> @Model.Species</p>
                            <p><strong>Giống:</strong> @Model.Breed</p>
                            <p><strong>Giới tính:</strong> @Model.Gender</p>
                            <p><strong>Tình trạng sức khỏe:</strong> @(string.IsNullOrWhiteSpace(Model.HealthStatus) ? "Đang theo dõi" : Model.HealthStatus)</p>
                            <p><strong>Cân nặng:</strong> @(Model.Weight.HasValue ? $"{Model.Weight.Value:N1} kg" : "Chưa cập nhật")</p>
                            <p><strong>Mô tả:</strong> @(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả" : Model.Description)</p>
                        </div>

                        <div class="mt-3">
                            <span class="badge badge-success px-3 py-2 mr-2">@Model.AdoptionStatus</span>
                            <span class="badge badge-secondary px-3 py-2">@Model.Status</span>
                        </div>

                        <button type="button" class="btn btn-success btn-lg w-100 mt-4" data-toggle="modal" data-target="#adoptionModal">
                            Đăng ký nhận nuôi ngay
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-3">Lịch sử tiêm chủng</h5>
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Tên Vaccine</th>
                                        <th>Ngày tiêm</th>
                                        <th>Ghi chú</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Vaccinations.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center text-muted">Chưa có dữ liệu tiêm chủng.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var item in Model.Vaccinations)
                                        {
                                            <tr>
                                                <td>@item.VaccineName</td>
                                                <td>@item.VaccinationDate.ToString("dd/MM/yyyy")</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card border-0 shadow-sm branch-box">
                    <div class="card-body">
                        <h5 class="mb-3">Thông tin chi nhánh</h5>
                        <p class="mb-2"><strong>Tên chi nhánh:</strong> @Model.BranchName</p>
                        <p class="mb-2"><strong>Địa chỉ:</strong> @Model.BranchAddress</p>
                        <p class="mb-0"><strong>Hotline:</strong> @(string.IsNullOrWhiteSpace(Model.BranchHotline) ? "Đang cập nhật" : Model.BranchHotline)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="adoptionModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Đăng ký nhận nuôi @Model.Name</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="adoptionForm" novalidate>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="adopterName">Họ tên</label>
                        <input id="adopterName" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label for="adopterPhone">Số điện thoại</label>
                        <input id="adopterPhone" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label for="adopterEmail">Email</label>
                        <input id="adopterEmail" type="email" class="form-control" required />
                    </div>
                    <div class="form-group mb-0">
                        <label for="adopterMessage">Lời nhắn / Lý do nhận nuôi</label>
                        <textarea id="adopterMessage" class="form-control" rows="4" placeholder="Nhập nội dung mong muốn của bạn..."></textarea>
                    </div>
                    <div id="adoptionError" class="text-danger small mt-2 d-none"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Gửi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="adoptionSuccessToast" class="adoption-toast d-none">
    <div class="adoption-toast-content">
        <strong>Thành công!</strong>
        <span>Yêu cầu nhận nuôi đã được gửi. PetCareHub sẽ liên hệ sớm.</span>
    </div>
</div>

<style>
    .pet-detail-page strong { color: #1f2937; }
    .detail-meta p { margin-bottom: .55rem; }
    .branch-box { border-left: 4px solid #28a745; }

    .adoption-toast {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 9999;
    }

    .adoption-toast-content {
        background: #28a745;
        color: #fff;
        border-radius: 10px;
        padding: .9rem 1rem;
        min-width: 260px;
        box-shadow: 0 .75rem 1.5rem rgba(40, 167, 69, .28);
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }
</style>

<script>
    (function () {
        const form = document.getElementById('adoptionForm');
        const errorBox = document.getElementById('adoptionError');
        const toast = document.getElementById('adoptionSuccessToast');

        function validateEmail(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
        }

        function validatePhone(phone) {
            return /^\d{9,11}$/.test((phone || '').replace(/\D/g, ''));
        }

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            errorBox.classList.add('d-none');

            const name = document.getElementById('adopterName').value.trim();
            const phone = document.getElementById('adopterPhone').value.trim();
            const email = document.getElementById('adopterEmail').value.trim();

            if (!name) {
                errorBox.textContent = 'Vui lòng nhập họ tên.';
                errorBox.classList.remove('d-none');
                return;
            }

            if (!phone || !validatePhone(phone)) {
                errorBox.textContent = 'Số điện thoại không hợp lệ (9-11 số).';
                errorBox.classList.remove('d-none');
                return;
            }

            if (!email || !validateEmail(email)) {
                errorBox.textContent = 'Email không đúng định dạng.';
                errorBox.classList.remove('d-none');
                return;
            }

            $('#adoptionModal').modal('hide');
            form.reset();
            toast.classList.remove('d-none');
            setTimeout(() => toast.classList.add('d-none'), 2800);
        });
    })();
</script>
