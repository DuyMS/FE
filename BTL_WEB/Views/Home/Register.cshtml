@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_LayoutPetcarehub.cshtml";
}

<section class="ftco-section bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h3 class="mb-3">Đăng ký tài khoản</h3>
                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label>Họ tên</label>
                                <input class="form-control" type="text" placeholder="Nguyễn Văn A" />
                            </div>
                            <div class="col-md-6 form-group mb-3">
                                <label>Số điện thoại</label>
                                <input class="form-control" type="text" placeholder="09xxxxxxxx" />
                            </div>
                            <div class="col-md-6 form-group mb-3">
                                <label>Email</label>
                                <input class="form-control" type="email" placeholder="you@example.com" />
                            </div>
                            <div class="col-md-6 form-group mb-3">
                                <label>Username</label>
                                <input class="form-control" type="text" placeholder="username" />
                            </div>
                            <div class="col-md-6 form-group mb-3">
                                <label>Mật khẩu</label>
                                <input class="form-control" type="password" placeholder="******" />
                            </div>
                            <div class="col-md-6 form-group mb-3">
                                <label>Nhập lại mật khẩu</label>
                                <input class="form-control" type="password" placeholder="******" />
                            </div>
                        </div>
                        <button class="btn btn-primary py-2 px-4">Tạo tài khoản</button>
                        <a asp-action="Login" class="btn btn-link">Đã có tài khoản? Đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
